// ===== VARIABLES INTERNAS DEL ADC =====
static adc_oneshot_unit_handle_t adc_handle;
static bool adc_inicializado = false;


// ===== INICIALIZACIÓN DEL SENSOR DE pH =====
void ph_init(int gpio_num) {

    adc_oneshot_unit_init_cfg_t config_adc = {
        .unit_id = ADC_UNIT_1,
    };

    adc_oneshot_new_unit(&config_adc, &adc_handle);


    adc_oneshot_chan_cfg_t config_canal = {
        .bitwidth = ADC_BITWIDTH_DEFAULT,
        .atten = ADC_ATTEN_DB_12,
    };

    // ⚠ Se usa canal 0 (GPIO36 normalmente)
    adc_oneshot_config_channel(adc_handle, ADC_CHANNEL_0, &config_canal);

    adc_inicializado = true;
}


// ===== LECTURA DEL pH =====
float ph_leer(int gpio_num) {

    if (!adc_inicializado) return 0.0;

    int valor_adc = 0;

    esp_err_t estado = adc_oneshot_read(adc_handle, ADC_CHANNEL_0, &valor_adc);

    if (estado == ESP_OK) {

        // Conversión ADC → Voltaje
        float voltaje = (valor_adc / 4095.0f) * 3.3f;

        // Conversión Voltaje → pH (GENÉRICA)
        float valor_ph = 3.5f * voltaje;

        return valor_ph;
    }
    else {
        return -1.0; // Error de lectura
    }
}
