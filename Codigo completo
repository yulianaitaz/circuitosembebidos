//  PINES INTERNOS
static int pin_clk, pin_dat, pin_rst;


//ESCRITURA DE BYTE 
static void ds1302_write_byte(uint8_t dato) {
    gpio_set_direction(pin_dat, GPIO_MODE_OUTPUT);

    for (int i = 0; i < 8; i++) {
        gpio_set_level(pin_dat, (dato >> i) & 1);

        esp_rom_delay_us(15);
        gpio_set_level(pin_clk, 1);
        esp_rom_delay_us(15);
        gpio_set_level(pin_clk, 0);
        esp_rom_delay_us(15);
    }
}


// LECTURA DE BYTE
static uint8_t ds1302_read_byte() {
    uint8_t dato = 0;

    gpio_set_direction(pin_dat, GPIO_MODE_INPUT);

    for (int i = 0; i < 8; i++) {
        gpio_set_level(pin_clk, 0);
        esp_rom_delay_us(15);

        if (gpio_get_level(pin_dat)) {
            dato |= (1 << i);
        }

        gpio_set_level(pin_clk, 1);
        esp_rom_delay_us(15);
        gpio_set_level(pin_clk, 0);
        esp_rom_delay_us(15);
    }

    return dato;
}


//  INICIALIZACIÓN 
void ds1302_init(int clk, int dat, int rst) {
    pin_clk = clk;
    pin_dat = dat;
    pin_rst = rst;

    gpio_reset_pin(pin_clk);
    gpio_set_direction(pin_clk, GPIO_MODE_OUTPUT);

    gpio_reset_pin(pin_dat);
    gpio_set_direction(pin_dat, GPIO_MODE_OUTPUT);

    gpio_reset_pin(pin_rst);
    gpio_set_direction(pin_rst, GPIO_MODE_OUTPUT);

    gpio_set_level(pin_rst, 0);
    gpio_set_level(pin_clk, 0);
}


//  CONVERSIÓN BCD 
static uint8_t bcd_a_decimal(uint8_t bcd) {
    return ((bcd >> 4) * 10) + (bcd & 0x0F);
}

static uint8_t decimal_a_bcd(uint8_t dec) {
    return ((dec / 10) << 4) | (dec % 10);
}


//LECTURA DE TIEMPO 
void ds1302_leer_tiempo(rtc_tiempo_t *tiempo) {

    rtc_tiempo_t tiempo_leido;

    // Lectura del RTC
    gpio_set_level(pin_rst, 1);
    esp_rom_delay_us(15);

    ds1302_write_byte(0xBF);

    tiempo_leido.segundo = bcd_a_decimal(ds1302_read_byte() & 0x7F);
    tiempo_leido.minuto  = bcd_a_decimal(ds1302_read_byte());
    tiempo_leido.hora    = bcd_a_decimal(ds1302_read_byte());
    tiempo_leido.dia     = bcd_a_decimal(ds1302_read_byte());
    tiempo_leido.mes     = bcd_a_decimal(ds1302_read_byte());

    ds1302_read_byte(); // día semana (no usado)

    tiempo_leido.anio = bcd_a_decimal(ds1302_read_byte()) + 2000;

    gpio_set_level(pin_rst, 0);


    //  FILTRO DE VALIDEZ 
    if (tiempo_leido.mes > 0 && tiempo_leido.mes <= 12 &&
        tiempo_leido.dia > 0 && tiempo_leido.dia <= 31 &&
        tiempo_leido.segundo < 60) {

        *tiempo = tiempo_leido;
    }
    else {
        // FALLA → SIMULACIÓN DE TIEMPO
        tiempo->segundo += 5;

        if (tiempo->segundo >= 60) {
            tiempo->segundo -= 60;
            tiempo->minuto++;

            if (tiempo->minuto >= 60) {
                tiempo->minuto = 0;
                tiempo->hora++;
            }
        }
    }
}


//AJUSTE DE TIEMPO 
void ds1302_fijar_tiempo(rtc_tiempo_t *tiempo) {

    gpio_set_level(pin_rst, 1);

    ds1302_write_byte(0x8E);
    ds1302_write_byte(0x00); // Unlock

    gpio_set_level(pin_rst, 0);
    esp_rom_delay_us(10);

    gpio_set_level(pin_rst, 1);

    ds1302_write_byte(0xBE); // Burst write

    ds1302_write_byte(decimal_a_bcd(tiempo->segundo));
    ds1302_write_byte(decimal_a_bcd(tiempo->minuto));
    ds1302_write_byte(decimal_a_bcd(tiempo->hora));
    ds1302_write_byte(decimal_a_bcd(tiempo->dia));
    ds1302_write_byte(decimal_a_bcd(tiempo->mes));
    ds1302_write_byte(0x01); // día semana
    ds1302_write_byte(decimal_a_bcd(tiempo->anio % 100));
    ds1302_write_byte(0x00);

    gpio_set_level(pin_rst, 0);
}
