// ===== RESET DEL BUS ONEWIRE =====
static esp_err_t onewire_reset(int gpio_pin) {
    gpio_set_direction(gpio_pin, GPIO_MODE_OUTPUT);
    gpio_set_level(gpio_pin, 0);
    esp_rom_delay_us(480);

    gpio_set_direction(gpio_pin, GPIO_MODE_INPUT);
    esp_rom_delay_us(70);

    int nivel = gpio_get_level(gpio_pin);

    esp_rom_delay_us(410);

    return (nivel == 0) ? ESP_OK : ESP_FAIL;
}


// ===== ESCRIBIR UN BIT =====
static void onewire_write_bit(int gpio_pin, int bit) {
    gpio_set_direction(gpio_pin, GPIO_MODE_OUTPUT);
    gpio_set_level(gpio_pin, 0);

    if (bit) {
        esp_rom_delay_us(6);
        gpio_set_direction(gpio_pin, GPIO_MODE_INPUT);
        esp_rom_delay_us(64);
    } else {
        esp_rom_delay_us(60);
        gpio_set_direction(gpio_pin, GPIO_MODE_INPUT);
        esp_rom_delay_us(10);
    }
}


// ===== LEER UN BIT =====
static int onewire_read_bit(int gpio_pin) {
    int bit_leido = 0;

    gpio_set_direction(gpio_pin, GPIO_MODE_OUTPUT);
    gpio_set_level(gpio_pin, 0);
    esp_rom_delay_us(6);

    gpio_set_direction(gpio_pin, GPIO_MODE_INPUT);
    esp_rom_delay_us(9);

    bit_leido = gpio_get_level(gpio_pin);

    esp_rom_delay_us(55);

    return bit_leido;
}


// ===== ESCRIBIR UN BYTE =====
static void onewire_write_byte(int gpio_pin, uint8_t dato) {
    for (int i = 0; i < 8; i++) {
        onewire_write_bit(gpio_pin, (dato >> i) & 1);
    }
}


// ===== LEER UN BYTE =====
static uint8_t onewire_read_byte(int gpio_pin) {
    uint8_t dato = 0;

    for (int i = 0; i < 8; i++) {
        if (onewire_read_bit(gpio_pin)) {
            dato |= (1 << i);
        }
    }

    return dato;
}


// ===== INICIALIZACIÓN =====
esp_err_t ds18b20_init(int gpio_num) {
    gpio_config_t config_gpio = {
        .mode = GPIO_MODE_INPUT_OUTPUT_OD,
        .pull_up_en = GPIO_PULLUP_ENABLE,
        .pin_bit_mask = (1ULL << gpio_num)
    };

    return gpio_config(&config_gpio);
}


// ===== LECTURA DE TEMPERATURA =====
esp_err_t ds18b20_leer_temp(int gpio_num, float *temperatura) {

    if (onewire_reset(gpio_num) != ESP_OK) return ESP_FAIL;

    onewire_write_byte(gpio_num, 0xCC); // Skip ROM
    onewire_write_byte(gpio_num, 0x44); // Convert T

    vTaskDelay(pdMS_TO_TICKS(800));

    if (onewire_reset(gpio_num) != ESP_OK) return ESP_FAIL;

    onewire_write_byte(gpio_num, 0xCC); // Skip ROM
    onewire_write_byte(gpio_num, 0xBE); // Read Scratchpad

    uint8_t lsb = onewire_read_byte(gpio_num);
    uint8_t msb = onewire_read_byte(gpio_num);

    int16_t valor_crudo = (msb << 8) | lsb;

    *temperatura = (float)valor_crudo / 16.0;

    return ESP_OK;
}
