static i2c_master_bus_handle_t bus_i2c_handle = NULL;
static i2c_master_dev_handle_t lcd_i2c_handle = NULL;


// ===== CONTROL DEL PCF8574 =====
#define LCD_PIN_RS        0x01
#define LCD_PIN_EN        0x04
#define LCD_PIN_BACKLIGHT 0x08


// ===== ENVÍO DE NIBBLE =====
static esp_err_t lcd_enviar_nibble(uint8_t nibble, bool rs) {

    uint8_t base_datos = LCD_PIN_BACKLIGHT | ((nibble & 0x0F) << 4);

    if (rs) base_datos |= LCD_PIN_RS;

    uint8_t secuencia[3];

    secuencia[0] = base_datos;
    secuencia[1] = base_datos | LCD_PIN_EN;
    secuencia[2] = base_datos;

    esp_err_t error = i2c_master_transmit(lcd_i2c_handle, secuencia, 3, 100);

    vTaskDelay(pdMS_TO_TICKS(2));

    return error;
}



static void lcd_enviar_byte(uint8_t valor, bool rs) {
    lcd_enviar_nibble((valor >> 4) & 0x0F, rs);
    lcd_enviar_nibble(valor & 0x0F, rs);
}



void lcd_send_cmd(uint8_t comando) {
    lcd_enviar_byte(comando, false);
    vTaskDelay(pdMS_TO_TICKS(2));
}



void lcd_send_data(uint8_t dato) {
    lcd_enviar_byte(dato, true);
    vTaskDelay(pdMS_TO_TICKS(1));
}



void lcd_init(void) {

    //
    i2c_master_bus_config_t config_bus = {
        .clk_source = I2C_CLK_SRC_DEFAULT,
        .i2c_port = I2C_NUM_0,
        .scl_io_num = LCD_SCL_GPIO,
        .sda_io_num = LCD_SDA_GPIO,
        .glitch_ignore_cnt = 7,
        .flags.enable_internal_pullup = true,
    };

    ESP_ERROR_CHECK(i2c_new_master_bus(&config_bus, &bus_i2c_handle));


    // ---- CONFIGURACIÓN DEL DISPOSITIVO ----
    i2c_device_config_t config_disp = {
        .device_address = LCD_ADDR,
        .scl_speed_hz = 10000,
    };

    ESP_ERROR_CHECK(i2c_master_bus_add_device(bus_i2c_handle, &config_disp, &lcd_i2c_handle));


    vTaskDelay(pdMS_TO_TICKS(50));


    // secuencia de inicialización
    for(int i = 0; i < 6; i++) {
        lcd_enviar_nibble(0x03, false);
        vTaskDelay(pdMS_TO_TICKS(10));
    }

    lcd_enviar_nibble(0x02, false);
    vTaskDelay(pdMS_TO_TICKS(10));


    // ---- CONFIG FINAL ----
    lcd_send_cmd(0x28); // 4 bits, 2 líneas
    lcd_send_cmd(0x0C); // Display ON
    lcd_send_cmd(0x06); // Cursor incrementa
    lcd_send_cmd(0x01); // Limpiar

    vTaskDelay(pdMS_TO_TICKS(5));
}


// 
void lcd_put_cur(int fila, int columna) {
    uint8_t posicion = (fila == 0) ? (0x80 + columna) : (0xC0 + columna);
    lcd_send_cmd(posicion);
}


// 
void lcd_send_string(char *texto) {
    while (*texto) {
        lcd_send_data((uint8_t)*texto++);
    }
}


// limppiar
void lcd_clear(void) {
    lcd_send_cmd(0x01);
} 
