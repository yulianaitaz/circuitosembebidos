float temperatura = 0;
float humedad = 0;
float temperatura_agua = 0;
float ph = 0;
int luz = 0;


// ===== ESTADOS DEL SISTEMA =====
static void evaluar_alertas() {

    // 🔴 ALERTA CRÍTICA
    if (ph < 5.5 || ph > 8.5 || temperatura > 35) {
        rgb_rojo();
        return;
    }

    // 🟡 ALERTA MEDIA
    if (ph < 6.0 || ph > 8.0) {
        rgb_amarillo();
        return;
    }

    // 🟢 NORMAL
    rgb_verde();
}


// ===== TAREA PRINCIPAL DE SENSORES =====
void tarea_sensores(void *pvParameters) {

    // ===== INICIALIZACIÓN =====
    dht_init(PIN_DHT);
    ds18b20_init(PIN_DS18B20);
    ph_init(PIN_LDR); // (ADC fijo en driver)
    ldr_init(PIN_LDR);

    rgb_init(PIN_RGB_R, PIN_RGB_G, PIN_RGB_B);

    lcd_init();

    ds1302_init(PIN_RTC_CLK, PIN_RTC_DAT, PIN_RTC_RST);


    while (1) {

        // ===== LECTURA DHT =====
        dht_read_data(PIN_DHT, &humedad, &temperatura);

        // ===== LECTURA DS18B20 =====
        ds18b20_leer_temp(PIN_DS18B20, &temperatura_agua);

        // ===== LECTURA pH =====
        ph = ph_leer(PIN_LDR);

        // ===== LDR =====
        luz = ldr_leer_estado(PIN_LDR);

        // ===== RTC =====
        rtc_tiempo_t tiempo;
        ds1302_leer_tiempo(&tiempo);

        // ===== ALERTAS =====
        evaluar_alertas();


        // ===== MOSTRAR EN LCD =====
        lcd_clear();

        lcd_put_cur(0, 0);
        char linea1[16];
        sprintf(linea1, "T:%.1f H:%.1f", temperatura, humedad);
        lcd_send_string(linea1);

        lcd_put_cur(1, 0);
        char linea2[16];
        sprintf(linea2, "pH:%.2f A:%.1f", ph, temperatura_agua);
        lcd_send_string(linea2);


        vTaskDelay(pdMS_TO_TICKS(2000));
    }
}
